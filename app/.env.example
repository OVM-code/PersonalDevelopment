# --- Required ---------------------------------------------------------------
# Your Anthropic API key (console.anthropic.com → API Keys).
# You pay for customers' usage; the fair-use cap below protects your margin.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Lemon Squeezy (payments) ------------------------------------------------
# From your Lemon Squeezy dashboard → Settings → Webhooks (signing secret).
LEMONSQUEEZY_WEBHOOK_SECRET=

# The "Buy" link of your CourseCraft product (Share → checkout link).
LEMONSQUEEZY_CHECKOUT_URL=

# --- Tuning -------------------------------------------------------------------
# Max API cost (USD) each customer may consume per month. Default 5.
# At €12/mo subscription and $5 cap, worst-case margin stays healthy.
MONTHLY_COST_CAP_USD=5

# Claude model (default claude-sonnet-5)
# MODEL=claude-sonnet-5

# SQLite database location (default ./data/coursecraft.db; /var/data on Render)
# DB_PATH=./data/coursecraft.db

# Port (default 3000)
# PORT=3000

# --- Local development only ----------------------------------------------------
# Lets you log in with this code instead of a real license key. NEVER set in production.
# DEV_ACCESS_CODE=letmein
